# Runtime
RAG_API_SECRET_KEY=replace-with-a-long-random-secret
RAG_ACCESS_TOKEN_MINUTES=720
RAG_CORS_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000

# PostgreSQL
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
RAG_DATABASE_URL=postgresql+psycopg2://rag:rag@postgres:5432/rag

# Qdrant
RAG_QDRANT_URL=http://qdrant:6333
RAG_QDRANT_COLLECTION=enterprise_documents
RAG_EMBEDDING_DIM=384

# Retrieval
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5

# LLM provider: mock, openai, gemini
RAG_LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
RAG_OPENAI_CHAT_MODEL=gpt-4o-mini
RAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini
GEMINI_API_KEY=
RAG_GEMINI_MODEL=gemini-2.5-flash
RAG_GEMINI_EMBEDDING_MODEL=embedding-001
